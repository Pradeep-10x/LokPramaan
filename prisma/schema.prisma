generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// this is administrative builing// kind of work station 
model AdminUnit {
  id        String        @id @default(uuid())
  name      String
  type      AdminUnitType
  parentId  String?
  centerLat Float?
  centerLng Float?
  parent    AdminUnit?    @relation("AdminUnitTree", fields: [parentId], references: [id])
  children  AdminUnit[]   @relation("AdminUnitTree")
  issues    Issue[]
  projects  Project[]
  users     User[]

  @@unique([name, parentId])
  @@index([parentId])
  @@index([type])
}

model User {
  id               String         @id @default(uuid())
  name             String
  email            String?        @unique
  passwordHash     String
  role             Role           @default(CITIZEN)
  isEmailVerified  Boolean        @default(false)
  adminUnitId      String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  auditActions     AuditLog[]     @relation("AuditActor")
  uploadedEvidence Evidence[]
  acceptedIssues   Issue[]        @relation("IssueAcceptedBy")
  rejectedIssues   Issue[]        @relation("IssueRejectedBy")
  assignedIssues   Issue[]        @relation("IssueAssignee")
  createdIssues    Issue[]        @relation("IssueCreator")
  inspectedIssues  Issue[]        @relation("IssueInspector")
  contractedIssues Issue[]        @relation("IssueContractor")
  createdProjects  Project[]      @relation("ProjectCreator")
  adminUnit        AdminUnit?     @relation(fields: [adminUnitId], references: [id])
  verifications    Verification[]
  notifications    UserNotification[]

  @@index([role])
  @@index([adminUnitId])
}

model Project {
  id          String        @id @default(uuid())
  title       String
  description String
  status      ProjectStatus @default(PROPOSED)
  adminUnitId String 
  createdById String
  budget      Decimal?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  auditLogs         AuditLog[]
  issues            Issue[]
  userNotifications UserNotification[]
  adminUnit         AdminUnit     @relation(fields: [adminUnitId], references: [id])
  createdBy         User          @relation("ProjectCreator", fields: [createdById], references: [id])

  @@index([adminUnitId])
  @@index([status])
}

model Issue {
  id               String            @id @default(uuid())
  title            String
  description      String?
  status           IssueStatus       @default(OPEN)
  wardId           String
  department       Department
  projectId        String?
  createdById      String
  assignedToId     String?
  inspectorId      String?
  contractorId     String?
  acceptedById     String?
  acceptedAt       DateTime?
  rejectedById     String?
  rejectedAt       DateTime?
  rejectionReason  String?
  slaDeadline      DateTime?
  latitude         Float
  longitude        Float
  duplicateOfId    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  auditLogs        AuditLog[]
  evidence         Evidence[]
  acceptedBy       User?             @relation("IssueAcceptedBy", fields: [acceptedById], references: [id])
  rejectedBy       User?             @relation("IssueRejectedBy", fields: [rejectedById], references: [id])
  assignedTo       User?             @relation("IssueAssignee", fields: [assignedToId], references: [id])
  inspector        User?             @relation("IssueInspector", fields: [inspectorId], references: [id])
  contractor       User?             @relation("IssueContractor", fields: [contractorId], references: [id])
  createdBy        User              @relation("IssueCreator", fields: [createdById], references: [id])
  duplicateOf      Issue?            @relation("IssueDuplicate", fields: [duplicateOfId], references: [id])
  duplicates       Issue[]           @relation("IssueDuplicate")
  project          Project?          @relation(fields: [projectId], references: [id])
  ward             AdminUnit         @relation(fields: [wardId], references: [id])
  notificationLogs  NotificationLog[]
  userNotifications UserNotification[]
  verification      Verification?

  @@index([wardId])
  @@index([status])
  @@index([assignedToId])
  @@index([inspectorId])
  @@index([contractorId])
  @@index([projectId])
}

model Evidence {
  id           String       @id @default(uuid())
  issueId      String
  type         EvidenceType
  fileUrl      String
  fileHash     String
  latitude     Float?
  longitude    Float?
  exifTime     DateTime?
  geoFallback  Boolean      @default(false)
  uploadedById String
  uploadedAt   DateTime     @default(now())
  issue        Issue        @relation(fields: [issueId], references: [id])
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])

  @@index([issueId])
  @@index([type])
}

model Verification {
  id           String              @id @default(uuid())
  issueId      String              @unique
  verifiedById String
  verdict      VerificationVerdict
  remarks      String?
  overrideNote String?
  verifiedAt   DateTime            @default(now())
  issue        Issue               @relation(fields: [issueId], references: [id])
  verifiedBy   User                @relation(fields: [verifiedById], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  issueId   String?
  projectId String?
  actorId   String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User     @relation("AuditActor", fields: [actorId], references: [id])
  issue     Issue?   @relation(fields: [issueId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])

  @@index([issueId])
  @@index([projectId])
  @@index([actorId])
}

model Resident {
  id        String   @id @default(uuid())
  name      String?
  phoneHash String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())

  @@index([phoneHash])
}

/// Log of notifications sent to residents about nearby issues
model NotificationLog {
  id            String              @id @default(uuid())
  issueId       String
  recipientHash String
  message       String
  channel       NotificationChannel
  status        String?
  sentAt        DateTime            @default(now())
  issue         Issue               @relation(fields: [issueId], references: [id])

  @@index([issueId])
}

enum Role {
  CITIZEN
  OFFICER
  INSPECTOR
  ADMIN
  CONTRACTOR
}

enum Department {
  MUNICIPAL
  ELECTRICITY
  WATER
  SANITATION
  HEALTH
  TRANSPORT
}

enum AdminUnitType {
  GLOBAL
  CITY
  WARD
}

enum ProjectStatus {
  PROPOSED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum IssueStatus {
  OPEN
  ACCEPTED
  REJECTED
  ASSIGNED
  INSPECTING          // inspector assigned, awaiting before photo
  CONTRACTOR_ASSIGNED // contractor hired, work in progress
  WORK_DONE           // contractor marked work complete
  UNDER_REVIEW        // inspector submitted after photo, awaiting officer verification
  IN_PROGRESS
  COMPLETED
  VERIFIED
}

enum EvidenceType {
  BEFORE
  AFTER
}

enum VerificationVerdict {
  APPROVED
  REJECTED
}

enum NotificationChannel {
  SMS
  WHATSAPP
  SYSTEM
}

/// In-app notifications for platform users (citizens, officers, inspectors, etc.)
model UserNotification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  issueId   String?
  projectId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  issue     Issue?   @relation(fields: [issueId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([userId, read])
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, otp])
  @@map("email_otps")
}
